{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationMap": false,
    "outDir": "./dist/types",
    "rootDir": "../.."
  },
  "include": [
    "src/index.ts",
    "src/run/**/*.ts",
    "src/run-display/**/*.ts",
    "src/run-display/**/*.tsx"
  ],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "../../src/**/*.test.ts",
    "../../src/**/*.test.tsx"
  ]
}
